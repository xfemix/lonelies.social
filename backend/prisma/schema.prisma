generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Category {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  description String
  order     Int
  posts     Post[]
}

enum PostType {
  FIX_MY_LIFE
  AM_I_DELUSIONAL
  WHY_DO_PEOPLE_AVOID_ME
  RATE_MY_SITUATION
  EXISTENTIAL_CRISIS
  SOCIAL_AUTOPSY
}

model Post {
  id          String   @id @default(uuid())
  title       String
  content     String
  type        PostType
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  // Aggregated voting metrics for truth scoring
  helpfulTruthCount Int     @default(0)
  justCruelCount    Int     @default(0)
  truthScore        Float   @default(0)

  // Resolution lifecycle
  resolvedAt  DateTime?

  // Children
  replies Reply[]
  votes   Vote[]
}

model Vote {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  voterId   String?
  voter     User?    @relation(fields: [voterId], references: [id])
  tag       VoteTag
  createdAt DateTime @default(now())
}

enum VoteTag {
  HELPFUL_TRUTH
  JUST_CRUEL
}

model Reply {
  id          String   @id @default(uuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  content     String
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  votes       ReplyVote[]
}

model ReplyVote {
  id        String   @id @default(uuid())
  replyId   String
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)
  voterId   String?
  voter     User?    @relation(fields: [voterId], references: [id])
  tag       VoteTag
  createdAt DateTime @default(now())
}

model Flag {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  flaggerId String?
  flagger   User?    @relation(fields: [flaggerId], references: [id])
  type      FlagType
  note      String?
  createdAt DateTime @default(now())
}

enum FlagType {
  DELUSIONAL
  CRUELTY
  OTHER
}
